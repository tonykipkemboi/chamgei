---
---

<section class="relative py-24 overflow-hidden">
  <div class="grad-divider mb-0"></div>
  <!-- background glow -->
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
    <div class="w-[800px] h-[400px] opacity-5" style="background:radial-gradient(ellipse, #0ea5e9 0%, transparent 70%); filter:blur(60px);"></div>
  </div>

  <div class="max-w-5xl mx-auto px-6 relative z-10">
    <div class="text-center mb-16">
      <h2 class="text-4xl sm:text-5xl font-bold mb-4 grad-text-white">Built with privacy in mind</h2>
      <p class="text-lg" style="color:#6b7fa0;">Your voice. Your data. Your machine.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div class="rounded-2xl p-7 border" style="background:#0c1528; border-color:rgba(14,165,233,0.15);">
        <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background:rgba(14,165,233,0.1);">
          <svg class="w-6 h-6" fill="none" stroke="#0ea5e9" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
              d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/>
          </svg>
        </div>
        <h3 class="font-semibold text-base mb-2" style="color:#e8f0fa;">Audio stays local by default</h3>
        <p class="text-sm leading-relaxed" style="color:#6b7fa0;">
          With <code class="font-mono text-xs px-1.5 py-0.5 rounded" style="background:#060d1a;color:#a78bfa;">stt_engine = "local"</code> audio never leaves your machine. Cloud engines send audio only for transcription — the transcript is never uploaded.
        </p>
      </div>

      <div class="rounded-2xl p-7 border" style="background:#0c1528; border-color:rgba(167,139,250,0.15);">
        <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background:rgba(167,139,250,0.1);">
          <svg class="w-6 h-6" fill="none" stroke="#a78bfa" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
              d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
          </svg>
        </div>
        <h3 class="font-semibold text-base mb-2" style="color:#e8f0fa;">API keys in macOS Keychain</h3>
        <p class="text-sm leading-relaxed" style="color:#6b7fa0;">
          Keys are stored in the system Keychain — never in plaintext config files or environment variables. Run <code class="font-mono text-xs px-1.5 py-0.5 rounded" style="background:#060d1a;color:#0ea5e9;">chamgei key list</code> to inspect.
        </p>
      </div>

      <div class="rounded-2xl p-7 border" style="background:#0c1528; border-color:rgba(52,211,153,0.15);">
        <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background:rgba(52,211,153,0.1);">
          <svg class="w-6 h-6" fill="none" stroke="#34d399" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
              d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/>
          </svg>
        </div>
        <h3 class="font-semibold text-base mb-2" style="color:#e8f0fa;">Zero telemetry</h3>
        <p class="text-sm leading-relaxed" style="color:#6b7fa0;">
          No analytics, no crash reports, no usage pings. The binary makes no network requests you haven't configured. Config and history files are chmod 0600.
        </p>
      </div>
    </div>
  </div>
  <div class="grad-divider mt-24"></div>
</section>
