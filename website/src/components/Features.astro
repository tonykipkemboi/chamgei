---
// Diverse, global sample — expanded out for the marquee.
const languages = [
  { flag: '🇺🇸', name: 'English' },
  { flag: '🇪🇸', name: 'Spanish' },
  { flag: '🇫🇷', name: 'French' },
  { flag: '🇩🇪', name: 'German' },
  { flag: '🇧🇷', name: 'Portuguese' },
  { flag: '🇮🇹', name: 'Italian' },
  { flag: '🇯🇵', name: 'Japanese' },
  { flag: '🇨🇳', name: 'Mandarin' },
  { flag: '🇰🇷', name: 'Korean' },
  { flag: '🇸🇦', name: 'Arabic' },
  { flag: '🇮🇳', name: 'Hindi' },
  { flag: '🇰🇪', name: 'Swahili' },
  { flag: '🇷🇺', name: 'Russian' },
  { flag: '🇳🇱', name: 'Dutch' },
  { flag: '🇹🇷', name: 'Turkish' },
  { flag: '🇵🇱', name: 'Polish' },
  { flag: '🇻🇳', name: 'Vietnamese' },
  { flag: '🇮🇩', name: 'Indonesian' },
  { flag: '🇬🇷', name: 'Greek' },
  { flag: '🇺🇦', name: 'Ukrainian' },
  { flag: '🇮🇱', name: 'Hebrew' },
  { flag: '🇵🇭', name: 'Filipino' },
  { flag: '🇹🇭', name: 'Thai' },
  { flag: '🇸🇪', name: 'Swedish' },
  { flag: '🇳🇴', name: 'Norwegian' },
  { flag: '🇩🇰', name: 'Danish' },
  { flag: '🇫🇮', name: 'Finnish' },
  { flag: '🇭🇺', name: 'Hungarian' },
  { flag: '🇨🇿', name: 'Czech' },
  { flag: '🇷🇴', name: 'Romanian' },
];

// Distribute languages across 5 parallax columns. Chips shuffled per column for visual variety.
const columnCount = 5;
const columnDurations = [62, 48, 78, 56, 70]; // seconds — prime-ish, avoids visible sync
const columnReverse   = [false, true, false, true, false];
const columns = Array.from({ length: columnCount }, (_, c) =>
  languages.filter((_, i) => i % columnCount === c)
);

// Real brand marks only, from Simple Icons (MIT licensed). Each path is the
// authentic logo — we render it in the brand's iOS-icon bg/fg so the tile
// reads as the real app rather than a stylized imitation.
//
// Mix spans notes, email, writing, chat, design, tasks, calls, messaging
// so the wall signals breadth beyond dev tools.
const apps = [
  { name: 'Notion', bg: '#FFFFFF', fg: '#111111',
