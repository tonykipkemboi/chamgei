// Honest + Small are rendered inline below with custom visuals.
---

<section id="features" class="relative py-20" style="background:var(--color-cream);">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Heading -->
    <div class="mb-16 max-w-2xl">
      <p class="text-[11px] font-mono uppercase mb-4" style="color:var(--color-ink-faint); letter-spacing:0.12em;">What it feels like</p>
      <h2 class="display" style="font-size:clamp(36px, 5vw, 56px);">
        Speaking <span class="display-italic" style="color:var(--color-teal);">should feel</span> like typing — only faster.
      </h2>
    </div>

    <!-- Feature: Any app -->
    <article>
      <p class="text-[11px] font-mono uppercase mb-3" style="color:var(--color-teal); letter-spacing:0.12em;">Any app</p>
      <h3 class="display mb-5" style="font-size:clamp(28px, 3.5vw, 40px);">Text appears where your cursor lives.</h3>
      <p class="body-serif max-w-2xl mb-10" style="font-size:18px;">
        It types into whatever is in front of you — a chart note, a Slack thread, a patient email, a pull-request review, a grant draft. No copy, no paste, no context switch.
      </p>

      <!-- App logo wall — iOS-style tiles, real brand marks (Simple Icons, MIT) -->
      <div class="grid grid-cols-4 md:grid-cols-8 gap-x-4 gap-y-6 justify-items-center py-4">
        {apps.map(a => (
          <div class="flex flex-col items-center gap-2.5">
            <div
              class="app-ios-tile"
              style={`position:relative; width:64px; height:64px; border-radius:16px; background:${a.bg}; box-shadow: 0 10px 24px -12px rgba(15,23,23,0.35), 0 2px 4px -2px rgba(15,23,23,0.15), inset 0 1px 0 rgba(255,255,255,0.18); display:flex; align-items:center; justify-content:center; overflow:hidden;`}
            >
              <div style="position:absolute; inset:0; background:linear-gradient(180deg, rgba(255,255,255,0.18) 0%, transparent 40%); pointer-events:none;"></div>
              <svg viewBox="0 0 24 24" width="32" height="32" fill={a.fg} aria-hidden="true" style="position:relative;"><path d={a.d}/></svg>
            </div>
            <span style="font-size:11px; color:var(--color-ink); font-weight:500;">{a.name}</span>
          </div>
        ))}
      </div>

      <p class="text-[12px] font-mono mt-5 text-center md:text-left" style="color:var(--color-ink-faint);">
        If it accepts keystrokes, rekody writes into it.
      </p>
    </article>
  </div>

  <!-- Feature: Languages — vertical parallax columns -->
  <article class="relative mt-24 mb-24 py-16 overflow-hidden" style="background:var(--color-cream-warm); border-top:1px solid var(--color-hairline); border-bottom:1px solid var(--color-hairline);">
    <div class="max-w-6xl mx-auto px-6 mb-10 text-center">
      <p class="text-[11px] font-mono uppercase mb-3" style="color:var(--color-teal); letter-spacing:0.12em;">100+ languages</p>
      <h3 class="display" style="font-size:clamp(28px, 3.5vw, 40px);">
        Speak <span class="display-italic" style="color:var(--color-teal);">however</span> you speak.
      </h3>
      <p class="body-serif mt-4 max-w-2xl mx-auto" style="font-size:18px;">
        Nova-3 hears the language you're speaking — and switches mid-sentence when you do.
      </p>
      <span class="inline-flex items-center gap-2 mt-6 px-4 py-2 rounded-full" style="background:var(--color-ink); color:var(--color-cream); font-size:12px; box-shadow:0 10px 30px -10px rgba(15,23,23,0.4);">
        <span class="w-1.5 h-1.5 rounded-full" style="background:var(--color-teal);"></span>
        auto-detect
      </span>
    </div>

    <!-- Parallax column stage -->
    <div class="max-w-6xl mx-auto px-6">
      <div class="col-stage" role="list" aria-label="Supported languages">
        {columns.map((col, idx) => (
          <div
            class={`col-track ${columnReverse[idx] ? 'reverse' : ''}`}
            style={`animation-duration: ${columnDurations[idx]}s;`}
            role="list"
          >
            {[...col, ...col].map((l, i) => (
              <span class="col-chip" role="listitem" aria-hidden={i >= col.length ? 'true' : 'false'}>
                <span class="flag" aria-hidden="true">{l.flag}</span>
                {l.name}
              </span>
            ))}
          </div>
        ))}
      </div>
    </div>

    <div class="max-w-6xl mx-auto px-6 mt-10 text-center">
      <p class="text-[12px] font-mono" style="color:var(--color-ink-faint);">
        …and ~80 more. <span style="color:var(--color-ink-mute);">Every language Deepgram Nova-3 supports.</span>
      </p>
    </div>
  </article>

  <!-- Remaining features: honesty + small -->
  <div class="max-w-6xl mx-auto px-6 flex flex-col gap-20">

    <!-- Honest by default — terminal mock proves the claim -->
    <article id="privacy" class="grid md:grid-cols-[1fr_380px] gap-12 items-center scroll-mt-24">
      <div>
        <p class="text-[11px] font-mono uppercase mb-3" style="color:var(--color-teal); letter-spacing:0.12em;">Honest by default</p>
        <h3 class="display mb-5" style="font-size:clamp(28px, 3.5vw, 40px);">Your words stay your words.</h3>
        <p class="body-serif max-w-xl" style="font-size:18px;">
          No analytics. No tracking. No phone-home. Your audio leaves this Mac only when you hold <span class="key">⌥</span> <span class="key">Space</span> — and only to the engine <em>you</em> picked. Update checks are manual: <code style="font-family:var(--font-mono);font-size:13px;color:var(--color-teal);">rekody update</code>. GitHub sees a download count. That's the entire footprint.
        </p>
      </div>

      <!-- Privacy report card -->
      <div class="rounded-2xl overflow-hidden" style="background:var(--color-ink); border:1px solid rgba(251,250,244,0.08); box-shadow:0 24px 60px -30px rgba(15,23,23,0.28);">
        <div class="px-6 pt-6 pb-5" style="border-bottom:1px solid rgba(251,250,244,0.08);">
          <p class="text-[10px] font-mono uppercase" style="color:rgba(251,250,244,0.45); letter-spacing:0.14em;">Data sent to us</p>
          <p class="display mt-2" style="font-size:56px; color:var(--color-cream); line-height:1; letter-spacing:-0.03em;">Nothing<span style="color:var(--color-teal);">.</span></p>
        </div>
        <div class="px-6 py-5 flex flex-col gap-3.5">
          {[
            { label: 'Analytics events',    value: '0' },
            { label: 'Trackers',            value: '0' },
            { label: 'Audio saved to disk', value: '0 bytes' },
            { label: 'Account required',    value: 'no' },
            { label: 'Cloud sync',          value: 'never' },
          ].map(row => (
            <div class="flex items-center justify-between">
              <span style="color:rgba(251,250,244,0.7); font-size:14px;">{row.label}</span>
              <span class="font-mono text-[13px]" style="color:var(--color-teal);">{row.value}</span>
            </div>
          ))}
        </div>
      </div>
    </article>

    <!-- Small + fast — size comparison bars -->
    <article class="grid md:grid-cols-[380px_1fr] gap-12 items-center">

      <!-- Bar chart -->
      <div class="rounded-2xl p-6" style="background:var(--color-cream-warm); border:1px solid var(--color-hairline); box-shadow:0 24px 60px -30px rgba(15,23,23,0.12);">
        <div class="flex items-baseline justify-between mb-5">
          <span class="text-[11px] font-mono uppercase" style="color:var(--color-ink-faint); letter-spacing:0.12em;">Binary size</span>
          <span class="text-[10px] font-mono uppercase" style="color:var(--color-ink-faint); letter-spacing:0.08em;">representative</span>
        </div>

        <div class="flex flex-col gap-5">
          <div>
            <div class="flex items-baseline justify-between mb-2">
              <span class="text-[13px] font-mono" style="color:var(--color-ink);">rekody</span>
              <span class="text-[13px] font-mono" style="color:var(--color-teal);">5 MB</span>
            </div>
            <div class="h-2 rounded-full overflow-hidden" style="background:rgba(15,23,23,0.06);">
              <div class="h-full rounded-full" style="width:6%; background:var(--color-teal);"></div>
            </div>
          </div>

          <div>
            <div class="flex items-baseline justify-between mb-2">
              <span class="text-[13px] font-mono" style="color:var(--color-ink-mute);">Electron app</span>
              <span class="text-[13px] font-mono" style="color:var(--color-ink-faint);">~250 MB</span>
            </div>
            <div class="h-2 rounded-full overflow-hidden" style="background:rgba(15,23,23,0.06);">
              <div class="h-full rounded-full" style="width:45%; background:rgba(15,23,23,0.35);"></div>
            </div>
          </div>

          <div>
            <div class="flex items-baseline justify-between mb-2">
              <span class="text-[13px] font-mono" style="color:var(--color-ink-mute);">JVM-based tool</span>
              <span class="text-[13px] font-mono" style="color:var(--color-ink-faint);">~800 MB</span>
            </div>
            <div class="h-2 rounded-full overflow-hidden" style="background:rgba(15,23,23,0.06);">
              <div class="h-full rounded-full" style="width:95%; background:rgba(15,23,23,0.35);"></div>
            </div>
          </div>
        </div>
      </div>

      <div>
        <p class="text-[11px] font-mono uppercase mb-3" style="color:var(--color-teal); letter-spacing:0.12em;">Small + fast</p>
        <h3 class="display mb-5" style="font-size:clamp(28px, 3.5vw, 40px);">A native binary. Not an Electron app.</h3>
        <p class="body-serif max-w-xl" style="font-size:18px;">
          Rust, compiled to a single binary. Launches in milliseconds, lives in the menu bar, stays out of your way. MIT — fork it, audit it, take it with you.
        </p>
      </div>
    </article>

  </div>
</section>
