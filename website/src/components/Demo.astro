---
const steps = [
  {
    num: '01',
    title: 'Hold',
    body: 'Hold <span class="key">⌥</span> <span class="key">Space</span> anywhere on macOS. A quiet indicator shows the mic is live.',
  },
  {
    num: '02',
    title: 'Speak',
    body: 'Talk normally. Silence gets trimmed; language auto-detects across 100+ tongues.',
  },
  {
    num: '03',
    title: 'Release',
    body: 'Let go. Text lands at your cursor — engine of your choice, no paste step.',
  },
];

// Pipeline stages with timing + tiny glyph
const pipeline = [
  { key: 'capture', label: 'Capture',  sub: 'Mic stream',     ms: '·',       icon: 'mic' },
  { key: 'vad',     label: 'Trim',     sub: 'VAD silences',   ms: '< 5ms',   icon: 'scissors' },
  { key: 'stt',     label: 'Transcribe', sub: 'Deepgram Nova-3', ms: '~180ms', icon: 'wave', highlight: true },
  { key: 'format',  label: 'Format',   sub: 'smart_format',   ms: '< 5ms',   icon: 'sparkle' },
  { key: 'inject',  label: 'Paste',    sub: 'CGEvent inject', ms: '< 10ms',  icon: 'cursor' },
];
---

<section id="how-it-works" class="relative max-w-6xl mx-auto px-6 py-20">
  <!-- Section heading -->
  <div class="mb-16 max-w-2xl">
    <p class="text-[11px] font-mono uppercase mb-4" style="color:var(--color-ink-faint); letter-spacing:0.12em;">How it works</p>
    <h2 class="display" style="font-size:clamp(36px, 5vw, 56px);">
      Three beats<span class="display-italic" style="color:var(--color-teal);">,</span> no friction.
    </h2>
    <p class="body-serif mt-5" style="font-size:18px;">
      Push to talk. Release to send. Desktop-grade latency, native to macOS.
    </p>
  </div>

  <!-- Steps grid -->
  <div class="grid md:grid-cols-3 gap-px rounded-2xl overflow-hidden" style="background:var(--color-hairline); border:1px solid var(--color-hairline);">
    {steps.map(s => (
      <article class="p-8 flex flex-col gap-5" style="background:var(--color-cream);">
        <div class="flex items-center justify-between">
          <span class="text-[11px] font-mono" style="color:var(--color-ink-faint); letter-spacing:0.08em;">{s.num}</span>
          <span class="display-italic" style="font-size:28px; color:var(--color-teal);">·</span>
        </div>
        <h3 class="display" style="font-size:40px;">{s.title}</h3>
        <p class="body-serif" style="font-size:16px;" set:html={s.body}></p>
      </article>
    ))}
  </div>

  <!-- Pipeline — visual flow -->
  <div class="mt-16 rounded-3xl overflow-hidden" style="background:var(--color-ink); color:var(--color-cream); border:1px solid rgba(251,250,244,0.06);">

    <!-- Header -->
    <div class="px-6 sm:px-8 pt-7 pb-5 flex items-center justify-between gap-4 flex-wrap">
      <div>
        <p class="text-[11px] font-mono uppercase mb-1" style="color:rgba(251,250,244,0.5); letter-spacing:0.12em;">Under the hood</p>
        <h3 class="display" style="font-size:clamp(22px, 2.8vw, 30px); color:var(--color-cream);">Five stages, start to cursor.</h3>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-[11px] font-mono" style="color:rgba(251,250,244,0.5); letter-spacing:0.08em;">END-TO-END</span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full" style="background:rgba(32,128,141,0.18); border:1px solid rgba(32,128,141,0.35); color:var(--color-teal);">
          <span class="relative inline-flex h-1.5 w-1.5">
            <span class="absolute inline-flex h-full w-full rounded-full animate-ping opacity-60" style="background:var(--color-teal);"></span>
            <span class="relative inline-flex rounded-full h-1.5 w-1.5" style="background:var(--color-teal);"></span>
          </span>
          <span class="font-mono text-[12px]">~200ms total</span>
        </span>
      </div>
    </div>

    <!-- Flow -->
    <div class="relative px-6 sm:px-8 pb-8">
      <div class="relative overflow-x-auto scrollbar-none">

        <!-- Conveyor lane (own row, above nodes) -->
        <div class="relative hidden sm:block mb-6 min-w-[640px]" aria-hidden="true">
          <div
            id="pipeline-lane"
            class="relative h-[60px] rounded-xl overflow-hidden"
            style="background:rgba(251,250,244,0.02); border:1px solid rgba(251,250,244,0.06);"
          >
            <!-- Tick marks aligned to node centers (10/30/50/70/90%) -->
            {[10, 30, 50, 70, 90].map(x => (
              <span class="absolute bottom-0 w-px h-2" style={`left:${x}%; background:rgba(251,250,244,0.15);`}></span>
            ))}
            <!-- Rail -->
            <div class="absolute left-[10%] right-[10%] top-1/2 -translate-y-1/2 h-px" style="background:linear-gradient(90deg, transparent, rgba(32,128,141,0.35) 10%, rgba(32,128,141,0.35) 90%, transparent);"></div>
            <!-- Traveling playhead glow -->
            <div
              id="pipeline-glow"
              class="absolute top-1/2 -translate-y-1/2 -translate-x-1/2 w-16 h-16 rounded-full pointer-events-none"
              style="left:10%; background:radial-gradient(circle, rgba(32,128,141,0.35) 0%, rgba(32,128,141,0) 70%); transition:left 1s cubic-bezier(0.65,0,0.35,1);"
            ></div>
            <!-- Payload (text/bars, no box) -->
            <div
              id="pipeline-payload"
              class="absolute top-1/2 flex items-center justify-center whitespace-nowrap"
              style="left:10%; transform:translate(-50%, -50%); transition:left 1s cubic-bezier(0.65,0,0.35,1), transform 1s cubic-bezier(0.65,0,0.35,1), opacity 0.3s ease-out; text-shadow:0 0 12px rgba(251,250,244,0.25);"
            ></div>
            <!-- Stage cursor caret (below lane, points to current stage) -->
            <div
              id="pipeline-caret"
              class="absolute -bottom-[5px] -translate-x-1/2 w-2 h-2 rotate-45"
              style="left:10%; background:var(--color-teal); box-shadow:0 0 10px rgba(32,128,141,0.6); transition:left 1s cubic-bezier(0.65,0,0.35,1);"
            ></div>
          </div>
        </div>

        <div class="relative grid grid-cols-5 min-w-[640px] gap-2">
          {pipeline.map((p, i) => (
            <div class="flex flex-col items-center text-center gap-3 px-1">
              <!-- Node -->
              <div
                class="relative w-16 h-16 rounded-2xl flex items-center justify-center"
                style={p.highlight
                  ? 'background:rgba(32,128,141,0.18); border:1px solid rgba(32,128,141,0.5); box-shadow:0 0 40px -8px rgba(32,128,141,0.6);'
                  : 'background:rgba(251,250,244,0.03); border:1px solid rgba(251,250,244,0.1);'}
              >
                <!-- Icons -->
                {p.icon === 'mic' && (
                  <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" style={`color:${p.highlight ? 'var(--color-teal)' : 'var(--color-cream)'};`}>
                    <rect x="9" y="3" width="6" height="12" rx="3"/><path d="M5 11a7 7 0 0 0 14 0M12 18v3"/>
                  </svg>
                )}
                {p.icon === 'scissors' && (
                  <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" style={`color:${p.highlight ? 'var(--color-teal)' : 'var(--color-cream)'};`}>
                    <circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M20 4 8.12 15.88M14.47 14.48 20 20M8.12 8.12 12 12"/>
                  </svg>
                )}
                {p.icon === 'wave' && (
                  <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" style={`color:${p.highlight ? 'var(--color-teal)' : 'var(--color-cream)'};`}>
                    <path d="M4 12v0M8 8v8M12 5v14M16 8v8M20 12v0"/>
                  </svg>
                )}
                {p.icon === 'sparkle' && (
                  <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" style={`color:${p.highlight ? 'var(--color-teal)' : 'var(--color-cream)'};`}>
                    <path d="M12 3v4M12 17v4M3 12h4M17 12h4M5.6 5.6l2.8 2.8M15.6 15.6l2.8 2.8M5.6 18.4l2.8-2.8M15.6 8.4l2.8-2.8"/>
                  </svg>
                )}
                {p.icon === 'cursor' && (
                  <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" style={`color:${p.highlight ? 'var(--color-teal)' : 'var(--color-cream)'};`}>
                    <path d="m3 3 7 19 2-8 8-2z"/>
                  </svg>
                )}
              </div>

              <!-- Stage number -->
              <span class="text-[10px] font-mono" style="color:rgba(251,250,244,0.4); letter-spacing:0.12em;">0{i + 1}</span>
              <!-- Label -->
              <div>
                <div class="display" style={`font-size:16px; color:${p.highlight ? 'var(--color-teal)' : 'var(--color-cream)'};`}>{p.label}</div>
                <div class="text-[11px] font-mono mt-0.5" style="color:rgba(251,250,244,0.5);">{p.sub}</div>
              </div>
              <!-- Timing chip -->
              <span class="text-[10px] font-mono px-2 py-0.5 rounded" style={`background:${p.highlight ? 'rgba(32,128,141,0.25)' : 'rgba(251,250,244,0.04)'}; color:${p.highlight ? 'var(--color-teal)' : 'rgba(251,250,244,0.55)'};`}>{p.ms}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Footer line -->
    <div class="px-6 sm:px-8 py-4 flex flex-wrap items-center justify-between gap-3 text-[11px] font-mono" style="border-top:1px solid rgba(251,250,244,0.08); color:rgba(251,250,244,0.5);">
      <span>Every stage runs in the rekody Rust binary. No browser, no Electron, no background daemon.</span>
      <span style="color:var(--color-teal);">audio in → text at cursor</span>
    </div>
  </div>
</section>

<style is:global>
  @keyframes p-bar-wave {
    0%, 100% { transform: scaleY(0.35); }
    50%      { transform: scaleY(1); }
  }
  .p-bar {
    display: inline-block;
    width: 2px;
    margin: 0 1.5px;
    background: var(--color-teal);
    border-radius: 1px;
    transform-origin: center;
    animation: p-bar-wave 1.3s ease-in-out infinite;
    box-shadow: 0 0 6px rgba(32,128,141,0.55);
  }
  #pipeline-payload { max-width: 80%; }
</style>

<script>
  const payload = document.getElementById('pipeline-payload') as HTMLElement | null;
  const glow    = document.getElementById('pipeline-glow')    as HTMLElement | null;
  const caret   = document.getElementById('pipeline-caret')   as HTMLElement | null;
  const target  = "move thursday's stand-up to 10.";
  const pool    = "!<>-_/=+*#@01·•→Xo?";
  const reduce  = window.matchMedia?.('(prefers-reduced-motion: reduce)').matches;

  function randChar() {
    return pool[Math.floor(Math.random() * pool.length)];
  }

  function bars(count: number, opts: { height?: number; minH?: number; live?: boolean } = {}) {
    const { height = 22, minH = 4, live = false } = opts;
    let html = '';
    for (let i = 0; i < count; i++) {
      const delay = (i * 0.09).toFixed(2);
      const h = minH + Math.round(Math.random() * (height - minH));
      const cls = live ? 'p-bar p-bar-live' : 'p-bar';
      html += `<span class="${cls}" style="animation-delay:${delay}s; height:${h}px;"></span>`;
    }
    return `<span class="inline-flex items-center">${html}</span>`;
  }

  let liveBarTimer: number | null = null;
  function startLiveBars(maxH: number, minH: number) {
    stopLiveBars();
    liveBarTimer = window.setInterval(() => {
      if (!payload) return;
      const bars = payload.querySelectorAll<HTMLElement>('.p-bar-live');
      bars.forEach(b => {
        const h = minH + Math.round(Math.random() * (maxH - minH));
        b.style.height = `${h}px`;
      });
    }, 120);
  }
  function stopLiveBars() {
    if (liveBarTimer !== null) { window.clearInterval(liveBarTimer); liveBarTimer = null; }
  }

  function textSpan(text: string, opts: { mono?: boolean; size?: number; color?: string; letter?: string; align?: string } = {}) {
    const { mono = true, size = 11, color = 'rgba(32,128,141,0.95)', letter = '0.08em' } = opts;
    const family = mono ? 'font-mono' : '';
    return `<span class="${family}" style="font-size:${size}px; letter-spacing:${letter}; color:${color};">${text}</span>`;
  }

  function setStage(left: string, html: string, align: 'center' | 'right' = 'center') {
    if (payload) {
      payload.style.left = left;
      // At stage 5 (90%), right-anchor the payload so its right edge sits at `left`
      payload.style.transform = align === 'right'
        ? 'translate(-100%, -50%)'
        : 'translate(-50%, -50%)';
      payload.innerHTML = html;
    }
    if (glow)  { glow.style.left = left; }
    if (caret) { caret.style.left = left; }
  }

  let scrambleTimer: number | null = null;
  function clearScramble() {
    if (scrambleTimer !== null) { window.clearInterval(scrambleTimer); scrambleTimer = null; }
  }

  async function sleep(ms: number) { return new Promise(r => window.setTimeout(r, ms)); }

  async function runLoop() {
    if (!payload) return;
    if (reduce) {
      setStage('50%', textSpan(target, { mono: false, size: 13, color: 'var(--color-teal)' }));
      return;
    }

    while (true) {
      // Stage 1 — Capture: LIVE mic waveform, bars re-sample while recording
      clearScramble();
      setStage('10%', bars(18, { height: 32, minH: 4, live: true }));
      startLiveBars(32, 4);
      await sleep(2800);
      stopLiveBars();

      // Stage 2 — Trim: VAD clipped silence, tighter bars, still live
      setStage('30%', bars(12, { height: 18, minH: 3, live: true }));
      startLiveBars(18, 3);
      await sleep(2000);
      stopLiveBars();

      // Stage 3 — Transcribe: scramble resolves to the sentence
      setStage('50%', textSpan('·'.repeat(target.length), { size: 11, letter: '0.12em', color: 'rgba(251,250,244,0.7)' }));
      await sleep(300);
      const scrambleDur = 2200;
      const scrambleStart = performance.now();
      await new Promise<void>((resolve) => {
        scrambleTimer = window.setInterval(() => {
          const elapsed = performance.now() - scrambleStart;
          const progress = Math.min(1, elapsed / scrambleDur);
          const eased = 1 - Math.pow(1 - progress, 2.4);
          const revealed = Math.floor(eased * target.length);
          let out = '';
          for (let i = 0; i < target.length; i++) {
            const ch = target[i];
            if (ch === ' ') { out += ' '; continue; }
            out += i < revealed ? ch : randChar();
          }
          if (payload) payload.innerHTML = textSpan(out, { size: 11, letter: '0.06em', color: 'var(--color-cream)' });
          if (progress >= 1) { clearScramble(); resolve(); }
        }, 65);
      });
      await sleep(600);

      // Stage 4 — Format: capitalized, punctuated
      const formatted = "Move Thursday's stand-up to 10.";
      setStage('70%', textSpan(formatted, { mono: false, size: 12, color: 'var(--color-cream)', letter: '0' }));
      await sleep(2400);

      // Stage 5 — Paste: sentence with blinking caret, right-anchored at stage 5
      setStage('90%', textSpan(formatted + '<span class="caret-blink" style="display:inline-block;width:1px;height:13px;background:var(--color-cream);margin-left:3px;vertical-align:middle;"></span>',
        { mono: false, size: 12, color: 'var(--color-cream)', letter: '0' }), 'right');
      await sleep(3200);

      // Fade and reset
      if (payload) payload.style.opacity = '0';
      if (glow)    glow.style.opacity    = '0';
      if (caret)   caret.style.opacity   = '0';
      await sleep(700);
      if (payload) payload.style.opacity = '1';
      if (glow)    glow.style.opacity    = '1';
      if (caret)   caret.style.opacity   = '1';
    }
  }

  runLoop();
</script>

<style is:global>
  @keyframes caret-blink {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0; }
  }
  .caret-blink { animation: caret-blink 0.9s step-start infinite; }
</style>
