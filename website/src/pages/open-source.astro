---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import OpenSource from '../components/OpenSource.astro';
import Footer from '../components/Footer.astro';

const title = 'Open source — rekody';
const description = 'rekody is MIT-licensed and open source. Six Rust crates, one CLI, everything on GitHub. Read it, audit it, fork it, run it forever.';
---

<Base title={title} description={description}>
  <Navbar />
  <main>
    <div style="height:4rem;"></div>
    <OpenSource />
  </main>
  <Footer />
</Base>
