---
import Base from '../layouts/Base.astro';
import LegalPage from '../components/LegalPage.astro';

const toc = [
  { id: 'overview',  label: 'Overview' },
  { id: 'current',   label: 'Current sub-processors' },
  { id: 'changes',   label: 'How we announce changes' },
  { id: 'object',    label: 'Objecting to a sub-processor' },
  { id: 'contact',   label: 'Contact' },
];

const title = 'Sub-processors — rekody';
const description = 'The third-party services rekody uses to operate. What they do, what data they see, and how we disclose changes.';
---

<Base title={title} description={description}>
  <LegalPage
    eyebrow="Sub-processors"
    title="Who we work with, and what they see."
    updated="April 22, 2026"
    summary="A sub-processor is a third-party service that processes your data on our behalf. We keep the list short on purpose. Every addition is an audit surface, so we only add vendors when a real service need justifies them."
    toc={toc}
  >
    <section id="overview">
      <h2>Overview</h2>
      <p>
        This page lists every third-party service that processes data on behalf of rekody. We update it whenever we add, remove, or swap a vendor. For the what-and-why of data handling generally, see our <a href="/privacy">privacy policy</a>.
      </p>
      <p>
        The open-source rekody CLI has no sub-processors operated by us — it runs on your Mac. If you configure a cloud provider with your own API key, you are sending data to that provider under their terms. We are not in the middle.
      </p>
    </section>

    <section id="current">
      <h2>Current sub-processors</h2>
      <p>
        This list is current as of the "Last updated" date above.
      </p>
      <table>
        <thead>
          <tr><th>Vendor</th><th>Purpose</th><th>Data processed</th><th>Location</th></tr>
        </thead>
        <tbody>
          <tr>
            <td>Vercel</td>
            <td>Website hosting and IP-anonymized analytics for <a href="https://rekody.com">rekody.com</a></td>
            <td>Page views, referrer, coarse geo, user agent</td>
            <td>US / global CDN</td>
          </tr>
          <tr>
            <td>GitHub</td>
            <td>Source code hosting, release distribution, issue tracker, discussions</td>
            <td>Public repository data; your GitHub account if you interact with the repo</td>
            <td>US</td>
          </tr>
          <tr>
            <td>Hugging Face</td>
            <td>Hosts the Whisper tiny model that the CLI downloads at install time</td>
            <td>Model download request (no user content)</td>
            <td>US / global CDN</td>
          </tr>
          <tr>
            <td>Homebrew</td>
            <td>Distributes the CLI via <code>brew install rekody</code></td>
            <td>Standard download telemetry per Homebrew's policies</td>
            <td>US / global CDN</td>
          </tr>
        </tbody>
      </table>
      <p>
        None of these vendors receives audio, transcripts, or any content you dictate.
      </p>
    </section>

    <section id="changes">
      <h2>How we announce changes</h2>
      <p>
        When we add, remove, or swap a sub-processor, we:
      </p>
      <ul>
        <li>Update this page with the new vendor and the "Last updated" date.</li>
        <li>Notify account holders by email at least <strong>30 days in advance</strong> of any material change — for example, routing audio through a new STT vendor, or switching to a new payment processor.</li>
        <li>For emergency changes driven by an incident with an existing vendor, we notify as quickly as practical — usually the same week — and explain why advance notice wasn't possible.</li>
      </ul>
    </section>

    <section id="object">
      <h2>Objecting to a sub-processor</h2>
      <p>
        If a planned change would affect your use of rekody, you can object by emailing <a href="mailto:support@rekody.com">support@rekody.com</a> during the notice period. If we cannot accommodate your objection, you may cancel your subscription for a prorated refund of the unused period.
      </p>
    </section>

    <section id="contact">
      <h2>Contact</h2>
      <p>
        Questions about this list: <a href="mailto:support@rekody.com">support@rekody.com</a>.
      </p>
    </section>
  </LegalPage>
</Base>
